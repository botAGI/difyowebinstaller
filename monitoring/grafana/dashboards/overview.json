{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(container_last_seen{name=~\"agmind-.*\"} > (time() - 60))",
          "legendFormat": "Running",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 8 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "CPU Usage by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"agmind-.*\"}[5m]) * 100",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "title": "Memory Usage by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"agmind-.*\"}",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"agmind-.*\"}[5m])",
          "legendFormat": "{{ name }} RX",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"agmind-.*\"}[5m])",
          "legendFormat": "{{ name }} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(container_fs_reads_bytes_total{name=~\"agmind-.*\"}[5m])",
          "legendFormat": "{{ name }} Read",
          "refId": "A"
        },
        {
          "expr": "rate(container_fs_writes_bytes_total{name=~\"agmind-.*\"}[5m])",
          "legendFormat": "{{ name }} Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agmind"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AGMind Overview",
  "uid": "agmind-overview"
}
