# =========================================
# AGMind .env — VPS Profile
# Public access via domain with TLS (certbot)
# =========================================

# --- Dify Version ---

# --- Secrets ---
SECRET_KEY=__SECRET_KEY__
DB_PASSWORD=__DB_PASSWORD__
REDIS_PASSWORD=__REDIS_PASSWORD__
SANDBOX_API_KEY=__SANDBOX_API_KEY__
PLUGIN_DAEMON_KEY=__PLUGIN_DAEMON_KEY__
PLUGIN_INNER_API_KEY=__PLUGIN_INNER_API_KEY__

# --- Database ---
DB_USERNAME=postgres
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dify

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USE_SSL=false
BROKER_USE_SSL=false

# --- Init Admin ---
INIT_PASSWORD=__ADMIN_PASSWORD_B64__

# --- URLs (auto-configured by nginx) ---
CONSOLE_WEB_URL=https://__DOMAIN__
CONSOLE_API_URL=https://__DOMAIN__
SERVICE_API_URL=https://__DOMAIN__
APP_API_URL=https://__DOMAIN__
APP_WEB_URL=https://__DOMAIN__
FILES_URL=https://__DOMAIN__

# --- Storage ---
STORAGE_TYPE=__STORAGE_TYPE__

# --- MinIO Object Storage ---
ENABLE_MINIO=__ENABLE_MINIO__
MINIO_ROOT_USER=__MINIO_ROOT_USER__
MINIO_ROOT_PASSWORD=__MINIO_ROOT_PASSWORD__
S3_ENDPOINT=__S3_ENDPOINT__
S3_BUCKET_NAME=__S3_BUCKET_NAME__
S3_ACCESS_KEY=__S3_ACCESS_KEY__
S3_SECRET_KEY=__S3_SECRET_KEY__
S3_REGION=us-east-1
S3_USE_AWS_MANAGED_IAM=false

# --- Vector Store ---
VECTOR_STORE=__VECTOR_STORE__
WEAVIATE_ENDPOINT=http://weaviate:8080
WEAVIATE_API_KEY=__WEAVIATE_API_KEY__
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=__QDRANT_API_KEY__

# --- ETL ---
ETL_TYPE=__ETL_TYPE__
UNSTRUCTURED_API_URL=http://docling:8765

# --- Document Processing ---
ENABLE_DOCLING=false
DOCLING_IMAGE=__DOCLING_IMAGE__
OCR_LANG=__OCR_LANG__
NVIDIA_VISIBLE_DEVICES=__NVIDIA_VISIBLE_DEVICES__

# --- Marketplace ---
MARKETPLACE_ENABLED=true
CHECK_UPDATE_URL=https://updates.dify.ai

# --- Sandbox ---
SANDBOX_ENABLE_NETWORK=true
SANDBOX_PORT=8194
SANDBOX_WORKER_TIMEOUT=15

# --- SSRF Proxy ---
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128

# --- Ollama ---
OLLAMA_API_BASE=http://ollama:11434
LLM_MODEL=__LLM_MODEL__
EMBEDDING_MODEL=__EMBEDDING_MODEL__

# --- Provider Architecture ---
LLM_PROVIDER=__LLM_PROVIDER__
EMBED_PROVIDER=__EMBED_PROVIDER__
TEI_EMBED_VERSION=__TEI_EMBED_VERSION__
VLLM_MODEL=__VLLM_MODEL__
HF_TOKEN=__HF_TOKEN__

# --- Reranker ---
ENABLE_RERANKER=__ENABLE_RERANKER__
TEI_RERANK_VERSION=__TEI_RERANK_VERSION__
RERANK_MODEL=__RERANK_MODEL__

# --- LiteLLM (AI Gateway) ---
LITELLM_MASTER_KEY=__LITELLM_MASTER_KEY__
ENABLE_LITELLM=__ENABLE_LITELLM__

# --- Optional Services ---
ENABLE_SEARXNG=__ENABLE_SEARXNG__
ENABLE_NOTEBOOK=__ENABLE_NOTEBOOK__
ENABLE_DBGPT=__ENABLE_DBGPT__
ENABLE_CRAWL4AI=__ENABLE_CRAWL4AI__
ENABLE_OPENWEBUI=__ENABLE_OPENWEBUI__
ENABLE_DIFY_PREMIUM=__ENABLE_DIFY_PREMIUM__
SEARXNG_SECRET_KEY=__SEARXNG_SECRET_KEY__
SURREALDB_PASSWORD=__SURREALDB_PASSWORD__
NOTEBOOK_ENCRYPTION_KEY=__NOTEBOOK_ENCRYPTION_KEY__
EXPOSE_DBGPT_PORT=5670
EXPOSE_NOTEBOOK_PORT=8502
EXPOSE_SEARXNG_PORT=8888
EXPOSE_CRAWL4AI_PORT=11235

# --- Nginx ---
EXPOSE_NGINX_PORT=80
EXPOSE_NGINX_SSL_PORT=443
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_HTTPS_ENABLED=true
NGINX_SERVER_NAME=__DOMAIN__

# --- Certbot ---
CERTBOT_EMAIL=__CERTBOT_EMAIL__
CERTBOT_DOMAIN=__DOMAIN__

# --- Open WebUI ---
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=user
ENABLE_OLLAMA_API=true
ENABLE_OPENAI_API=false
OLLAMA_BASE_URL=
OPENAI_API_BASE_URL=

# --- Plugin Daemon ---
PLUGIN_DAEMON_PORT=5002
PLUGIN_DB_DATABASE=dify_plugin
PLUGIN_STORAGE_TYPE=local
PLUGIN_STORAGE_LOCAL_PATH=/app/storage
PLUGIN_DIFY_INNER_API_URL=http://api:5001
MAX_PLUGIN_PACKAGE_SIZE=52428800
PLUGIN_PPROF_ENABLED=false

# --- Other versions ---

# --- TLS ---
TLS_MODE=__TLS_MODE__

# --- Monitoring ---
MONITORING_MODE=__MONITORING_MODE__
MONITORING_ENDPOINT=__MONITORING_ENDPOINT__
MONITORING_TOKEN=__MONITORING_TOKEN__
GRAFANA_PORT=3001
GRAFANA_BIND_ADDR=__GRAFANA_BIND_ADDR__
GRAFANA_ADMIN_PASSWORD=__GRAFANA_ADMIN_PASSWORD__
PORTAINER_PORT=9443
PORTAINER_BIND_ADDR=__PORTAINER_BIND_ADDR__

# --- Alerts (default: none; customer chooses channel via wizard) ---
# Opt-in channels — ALERT_MODE picks which block in alertmanager.yml is active.
# One of: none | telegram | email | webhook
ALERT_MODE=__ALERT_MODE__
ALERT_WEBHOOK_URL=__ALERT_WEBHOOK_URL__
ALERT_TELEGRAM_TOKEN=__ALERT_TELEGRAM_TOKEN__
ALERT_TELEGRAM_CHAT_ID=__ALERT_TELEGRAM_CHAT_ID__
ALERT_EMAIL_TO=__ALERT_EMAIL_TO__
ALERT_EMAIL_FROM=__ALERT_EMAIL_FROM__
ALERT_EMAIL_SMARTHOST=__ALERT_EMAIL_SMARTHOST__
ALERT_EMAIL_AUTH_USER=__ALERT_EMAIL_AUTH_USER__
ALERT_EMAIL_AUTH_PASS=__ALERT_EMAIL_AUTH_PASS__

# --- New service versions ---

# --- Security ---
ENABLE_UFW=true
ENABLE_FAIL2BAN=true
ENABLE_SOPS=true
SKIP_DOCKER_HARDENING=false
ENABLE_SECRET_ROTATION=false
LAN_SUBNET=192.168.0.0/16
SKIP_PREFLIGHT=false
SKIP_GPU_DETECT=false
FORCE_GPU_TYPE=

# --- Deploy ---
DEPLOY_ENV=PRODUCTION
LOG_LEVEL=INFO
MIGRATION_ENABLED=true
NEXT_TELEMETRY_DISABLED=1
FORCE_VERIFYING_SIGNATURE=true

# --- Authelia ---
ENABLE_AUTHELIA=false
AUTHELIA_JWT_SECRET=__AUTHELIA_JWT_SECRET__

# --- Healthchecks ---
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_RETRIES=5

# --- Backup Options ---
BACKUP_RETENTION_COUNT=10
ENABLE_S3_BACKUP=false
ENABLE_BACKUP_ENCRYPTION=false
S3_REMOTE_NAME=s3
S3_BUCKET=agmind-backups
S3_PATH=

# --- Loki ---
ENABLE_LOKI=true

# --- Performance tuning (added 2026-04-20) ---
# VPS values: conservative (typical 8-16 GiB RAM, no GPU). See env.lan.template для DGX Spark.

# Docling — VPS обычно без GPU, docling-serve работает на CPU fallback или отсутствует.
# Если docling не используется — эти vars игнорируются.
DOCLING_SERVE_LAYOUT_BATCH_SIZE=16
DOCLING_SERVE_OCR_BATCH_SIZE=16

# --- Upload limits (upstream Dify defaults are too conservative for KB ingest) ---
UPLOAD_FILE_SIZE_LIMIT=500
UPLOAD_FILE_BATCH_LIMIT=50
BATCH_UPLOAD_LIMIT=100
WORKFLOW_FILE_UPLOAD_LIMIT=50
