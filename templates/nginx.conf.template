    #__TLS__        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #__TLS__        proxy_set_header X-Forwarded-Proto $scheme;
    #__TLS__        proxy_set_header Upgrade $http_upgrade;
    #__TLS__        proxy_set_header Connection "upgrade";
    #__TLS__        proxy_read_timeout 600s;
