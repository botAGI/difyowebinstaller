    #__TLS__    ssl_prefer_server_ciphers on;
    #__TLS__    ssl_session_cache shared:SSL:10m;
    #__TLS__    ssl_session_timeout 10m;
    #__TLS__    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    #__TLS__
    #__TLS__    # Certbot challenge
