        #__OPENWEBUI__    proxy_buffering off;
        #__OPENWEBUI__}

        # =============================================
        # Block old-style hex token URLs (security)
        # =============================================
        location ~ "^/[a-f0-9]{24,}/" {
            return 404;
        }
    }

