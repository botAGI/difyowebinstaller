    #__TLS__        root /var/www/certbot;
    #__TLS__    }
    #__TLS__
    #__TLS__    #__AUTHELIA__# Authelia verify endpoint
    #__TLS__    #__AUTHELIA__location /api/verify {
    #__TLS__    #__AUTHELIA__    internal;
    #__TLS__    #__AUTHELIA__    proxy_pass http://authelia:9091/api/verify;
    #__TLS__    #__AUTHELIA__    proxy_pass_request_body off;
    #__TLS__    #__AUTHELIA__    proxy_set_header Content-Length "";
    #__TLS__    #__AUTHELIA__    proxy_set_header X-Original-URL $scheme://$http_host$request_uri;
    #__TLS__    #__AUTHELIA__    proxy_set_header X-Forwarded-For $remote_addr;
    #__TLS__    #__AUTHELIA__    proxy_set_header X-Forwarded-Proto $scheme;
    #__TLS__    #__AUTHELIA__}
    #__TLS__    #__AUTHELIA__
    #__TLS__    #__AUTHELIA__# Authelia portal
    #__TLS__    #__AUTHELIA__location /authelia {
    #__TLS__    #__AUTHELIA__    proxy_pass http://authelia:9091;
    #__TLS__    #__AUTHELIA__    proxy_set_header Host $host;
    #__TLS__    #__AUTHELIA__    proxy_set_header X-Real-IP $remote_addr;
    #__TLS__    #__AUTHELIA__    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #__TLS__    #__AUTHELIA__    proxy_set_header X-Forwarded-Proto $scheme;
    #__TLS__    #__AUTHELIA__}
    #__TLS__
    #__TLS__    # Health endpoint — no auth, rate limited
    #__TLS__    location = /health {
    #__TLS__    #__AUTHELIA__    auth_request off;
    #__TLS__        default_type application/json;
