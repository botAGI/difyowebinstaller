# =========================================
# AGMind .env — VPN Profile
# Access via VPN, optional internal domain
# =========================================

# --- Dify Version ---

# --- Secrets ---
SECRET_KEY=__SECRET_KEY__
DB_PASSWORD=__DB_PASSWORD__
REDIS_PASSWORD=__REDIS_PASSWORD__
SANDBOX_API_KEY=__SANDBOX_API_KEY__
PLUGIN_DAEMON_KEY=__PLUGIN_DAEMON_KEY__
PLUGIN_INNER_API_KEY=__PLUGIN_INNER_API_KEY__

# --- Database ---
DB_USERNAME=postgres
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dify

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USE_SSL=false
BROKER_USE_SSL=false

# --- Init Admin ---
INIT_PASSWORD=__ADMIN_PASSWORD_B64__

# --- URLs (empty = auto) ---
CONSOLE_WEB_URL=
CONSOLE_API_URL=
SERVICE_API_URL=
APP_API_URL=
APP_WEB_URL=
FILES_URL=

# --- Storage ---
STORAGE_TYPE=local

# --- Vector Store ---
VECTOR_STORE=__VECTOR_STORE__
WEAVIATE_ENDPOINT=http://weaviate:8080
WEAVIATE_API_KEY=WVF5YThaHlkYwhGUSmCRgsX3tD5ngdN8pkih
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=__QDRANT_API_KEY__

# --- ETL ---
ETL_TYPE=__ETL_TYPE__
UNSTRUCTURED_API_URL=http://docling:8765

# --- Reranker (Xinference) ---
XINFERENCE_BASE_URL=http://xinference:9997
RERANK_MODEL_NAME=bce-reranker-base_v1

# --- Marketplace ---
MARKETPLACE_ENABLED=true
CHECK_UPDATE_URL=https://updates.dify.ai

# --- Sandbox ---
SANDBOX_ENABLE_NETWORK=true
SANDBOX_PORT=8194
SANDBOX_WORKER_TIMEOUT=15

# --- SSRF Proxy ---
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128

# --- Ollama ---
OLLAMA_API_BASE=http://ollama:11434
LLM_MODEL=__LLM_MODEL__
EMBEDDING_MODEL=__EMBEDDING_MODEL__

# --- Nginx ---
EXPOSE_NGINX_PORT=80
EXPOSE_NGINX_SSL_PORT=443
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_HTTPS_ENABLED=false
NGINX_SERVER_NAME=_

# --- Pipeline (OpenAI proxy to Dify) ---
DIFY_API_KEY=

# --- Open WebUI ---
COMPANY_NAME=__COMPANY_NAME__
ENABLE_SIGNUP=false
ENABLE_OLLAMA_API=false

# --- Plugin Daemon ---
PLUGIN_DAEMON_PORT=5002
PLUGIN_DB_DATABASE=dify_plugin
PLUGIN_STORAGE_TYPE=local
PLUGIN_STORAGE_LOCAL_PATH=/app/storage
PLUGIN_DIFY_INNER_API_URL=http://api:5001
MAX_PLUGIN_PACKAGE_SIZE=52428800
PLUGIN_PPROF_ENABLED=false

# --- Other versions ---

# --- TLS ---
TLS_MODE=__TLS_MODE__

# --- Monitoring ---
MONITORING_MODE=__MONITORING_MODE__
MONITORING_ENDPOINT=__MONITORING_ENDPOINT__
MONITORING_TOKEN=__MONITORING_TOKEN__
GRAFANA_PORT=3001
GRAFANA_BIND_ADDR=0.0.0.0
GRAFANA_ADMIN_PASSWORD=__GRAFANA_ADMIN_PASSWORD__
PORTAINER_PORT=9443
PORTAINER_BIND_ADDR=0.0.0.0

# --- Alerts ---
ALERT_MODE=__ALERT_MODE__
ALERT_WEBHOOK_URL=__ALERT_WEBHOOK_URL__
ALERT_TELEGRAM_TOKEN=__ALERT_TELEGRAM_TOKEN__
ALERT_TELEGRAM_CHAT_ID=__ALERT_TELEGRAM_CHAT_ID__

# --- New service versions ---

# --- Security ---
ENABLE_UFW=false
ENABLE_FAIL2BAN=true
ENABLE_SOPS=false
SKIP_DOCKER_HARDENING=false
ENABLE_SECRET_ROTATION=false
LAN_SUBNET=192.168.0.0/16
VPN_INTERFACE=tun0
SKIP_PREFLIGHT=false
SKIP_GPU_DETECT=false
FORCE_GPU_TYPE=

# --- Deploy ---
DEPLOY_ENV=PRODUCTION
LOG_LEVEL=INFO
MIGRATION_ENABLED=true
NEXT_TELEMETRY_DISABLED=1
FORCE_VERIFYING_SIGNATURE=true

# --- Authelia ---
ENABLE_AUTHELIA=false
AUTHELIA_JWT_SECRET=__AUTHELIA_JWT_SECRET__

# --- Healthchecks ---
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_RETRIES=5

# --- Backup Options ---
BACKUP_RETENTION_COUNT=
ENABLE_S3_BACKUP=false
ENABLE_BACKUP_ENCRYPTION=false
S3_REMOTE_NAME=s3
S3_BUCKET=agmind-backups
S3_PATH=

# --- Loki ---
ENABLE_LOKI=true
