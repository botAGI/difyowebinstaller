# --- Core ---
DIFY_VERSION=1.13.3
# Wait for 1.14.1 (milestone due 2026-05-11) before bumping — 1.14.0 has open
# Iteration+Parallel regression (#35836) and variable-assigner v2 UI crash
# (наш блокер) скорее всего ещё не починен. См. memory project_dify_version_status.
OPENWEBUI_VERSION=v0.9.5
# arm64 manifest verified 2026-05-11. Bumped from v0.9.2 (3 patch ahead).
# Open WebUI Pipelines удалён 2026-04-26 — RAG лежит в Dify (и в RAGFlow #999.7),
# OpenWebUI используется только как chat UI. Pipelines extension framework
# (custom filters / message preprocessing) нам не нужен. Экономия: ~500 MB pull,
# ~200-400 MiB RAM на контейнер. Чтобы вернуть — restore commit с PIPELINES_VERSION.
OLLAMA_VERSION=0.21.2
# NOTE: Ollama 0.20.x is available but major jump from 0.6 — test before upgrading
POSTGRES_VERSION=16-alpine3.23
REDIS_VERSION=7.4.8-alpine

# --- Vector Stores ---
WEAVIATE_VERSION=1.37.2
# NOTE: Weaviate 1.36.9 available — requires data migration testing
QDRANT_VERSION=v1.17.1
# arm64 manifest verified 2026-05-11 (72.8 MB).
# Profile is opt-in (VECTOR_STORE=qdrant); default stack uses Weaviate, so no
# data migration needed — bump только меняет образ для новых установок.
# Bumped from v1.8.3 (May 2024) → v1.17.1 (Mar 2026): +9 minor releases.
# Notable между ними: ColBERT/ColPali multivector (1.10), sparse+IDF/BM25 (1.10),
# float16 vectors (1.10), HNSW compression (1.13), 1.5/2-bit quantization (1.15),
# multilingual tokenizer + Snowball + RU stopwords (1.15), Inline HNSW storage
# (1.16, ~10× для disk-bound), ACORN-1 filtered search (1.16), Weighted RRF (1.17).
# v1.17 BREAKING для gRPC clients: response format vector fields. REST не затронут.
# Если когда-то активируем qdrant profile с реальными данными — миграция потребует
# blue/green path (RocksDB → Gridstore irreversible с 1.16).

# Milvus — optional 3rd vector store (profile=milvus, opt-in через
# VECTOR_STORE=milvus). Use cases: клиент уже на Milvus / коллекции >50M chunks /
# multilingual built-in BM25 (CJK + RU одновременно).
# arm64 manifest verified 2026-05-11. v2.6 = stable production-ready, последний
# 2.6.15 (2026-04-24, security CVE-2026-26190 fix).
# v2.6 фичи vs 2.5: Woodpecker WAL (zero-disk, S3-mode 750 MB/s), Tiered Storage
# (12 GiB idle vs 430 GiB), built-in BM25 + ICU/Lindera/Jieba токенайзеры,
# online schema updates. Compose с reuse agmind-minio (см. docker-compose.yml).
# RAGFlow НЕ совместим с Milvus (PR #6367 closed not merged) → только Dify-only.
MILVUS_VERSION=v2.6.15
MILVUS_ETCD_VERSION=v3.5.25

# --- Infrastructure ---
SANDBOX_VERSION=0.2.14
SQUID_VERSION=6.6-24.04_edge
NGINX_VERSION=1.30.0-alpine
CERTBOT_VERSION=v3.1.0
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
# 🚨 HOLD на 2025-09-07 — последний release с arm64 manifest.
# Verified 2026-05-11: RELEASE.2025-09-30, 2025-10-08, 2025-10-15 — arm64 dropped
# из multi-arch manifest (только amd64). Тот же класс бага что cAdvisor v0.56+.
# НЕ bumpить minio:RELEASE.2025-09-30+ пока upstream не вернёт arm64 — для GB10 не работает.
# Перед любым bump: docker manifest inspect minio/minio:<tag> | grep -c arm64 → MUST be ≥1.
# MinIO Client (mc) — used by install.sh для bucket bootstrap + S3 service account.
# Forward-compatible с MinIO server 2024-11. arm64 manifest verified 2026-04-25.
MC_VERSION=RELEASE.2025-08-13T08-35-41Z
PLUGIN_DAEMON_VERSION=0.5.3-local
# Golden stable — pinned by upstream Dify 1.13.3 itself in their docker-compose.yaml
# 0.5.4: null-content regression (#640) breaks agent tool calling + uv --offline (#649) breaks install
# 0.5.5: reverts uv --offline but STILL carries #640
# 0.5.6: broken auto-migrate (#672 removed migrate, CLI missing from image, #521)
# Unblock when upstream ships 0.5.7 fixing #640 and re-adding migrate

# --- ETL ---
# Docling 1.17 has RapidOcr regression: container ищет PP-OCRv4 ONNX model которая
# не вшита в образ и нет auto-download → startup FAIL. Stay на 1.16.1 пока upstream
# не починит OR не добавим pre-warm step (download models в volume до start).
DOCLING_IMAGE_CPU=ghcr.io/docling-project/docling-serve:v1.16.1
DOCLING_IMAGE_CUDA=quay.io/docling-project/docling-serve-cu130:v1.16.1

