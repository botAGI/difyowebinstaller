ALLOY_VERSION=v1.16.0

# SOPS — secrets encryption tool downloaded from GitHub releases (lib/security.sh).
# SHA256 mandatory: refuse install if mismatch. Verify via checksums.txt at:
# https://github.com/getsops/sops/releases/download/v3.12.2/sops-v3.12.2.checksums.txt
SOPS_VERSION=v3.12.2
SOPS_SHA256_ARM64=f66de6f528dca946e910d74fa36a62a7714c11d0db16bd3c9bd8acf73b66704b
SOPS_SHA256_AMD64=14e2e1ba3bef31e74b70cf0b674f6443c80f6c5f3df15d05ffc57c34851b4998

# --- RAGFlow (BACKLOG #999.7) ---
# Pre-built RAGFlow v0.24.1-spark image для DGX Spark (GB10/SM_121/aarch64/CUDA 13).
# Self-built из HendrikSchoettle/ragflow-dgx-spark patches + наши cherry-picks из
# upstream main (TitleChunker/TokenChunker + 7 ingestion templates). Pushed в
# DockerHub 2026-04-27. Pin by digest — защита от tag mutation.
# Includes (base v0.24.0 + наши patches):
#   • RAGFlow v0.24.0 backend + Hendrik patches (multilingual OCR Latin/Cyrillic/
#     Chinese cascade, file metadata в ES chunks, AVIF, find_codec, IMAP fix,
#     WebDAV mtime, ONNX Runtime GPU 1.25.0 aarch64+CUDA13+SM121)
#   • Cherry-pick из upstream main (2026-04-27):
#     - rag/flow/chunker/ — TokenChunker (atomic table chunks + image_context)
#       + TitleChunker (5 уровней regex hierarchy для книг/законов/мануалов)
#     - rag/flow/parser/pdf_chunk_metadata.py — PDF positions tracking
#     - deepdoc/parser/utils.py — extract_pdf_outlines
#     - 7 новых ingestion templates: book/general/laws/manual/one/paper/resume
#   • Наши runtime patches:
#     - rag/llm/cv_model.py — русский prompt для image describe (вместо
#       hardcoded English) когда KB.language == "Russian"
#     - rag/prompts/vision_llm_describe_prompt.md — описание иллюстраций на
#       русском (rule 9-10 для non-text + scanned tables → HTML)
#     - rag/flow/pipeline.py — Pipeline.globals init (баг Hendrik fork v0.24
#       где Pipeline не наследовал от Canvas → AttributeError при first chunk)
#     - Russian title/description в 10 ingestion pipeline templates
# Pull ~13.3 GB → 5-10 мин на хорошем internet.
# Чтобы пересобрать — см. backlog 999.7.x. Список patches минимальный, легко
# вмерджить новый upstream tag поверх.
RAGFLOW_VERSION=v0.24.1-spark
RAGFLOW_DIGEST=sha256:4a0eff2da9bf1ca95d20c4345e2217397a6f40e3e9665105db9d68b4998d6dbe
RAGFLOW_IMAGE=ar2r223/ragflow-spark@${RAGFLOW_DIGEST}

# Elasticsearch 9.x — native arm64. RAGFlow main moved from 8.11 → 9.x.
RAGFLOW_ES_VERSION=9.0.2

# MySQL 8.0.x — RAGFlow has no Postgres support, MySQL is hardcoded в schema.
RAGFLOW_MYSQL_VERSION=8.0.39

# Elasticsearch Prometheus exporter — sidecar для ES метрик (heap, indices,
# cluster health, queries). Native /_prometheus/metrics в ES 9.x не работает
# (требует X-Pack proprietary plugin), поэтому отдельный exporter.
# Multi-arch verified 2026-04-28: linux/arm64/v8 + amd64.
ELASTICSEARCH_EXPORTER_VERSION=v1.9.0
