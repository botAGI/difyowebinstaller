# =========================================
# AGMind — Latest Verified Versions
# Source of truth for `agmind update --check`
# Updated: 2026-03-27 (aligned with Dify 1.13.3 defaults)
# =========================================

# --- Core ---
DIFY_VERSION=1.13.3
OPENWEBUI_VERSION=v0.8.12
PIPELINES_VERSION=main
OLLAMA_VERSION=0.6.2
POSTGRES_VERSION=15-alpine
REDIS_VERSION=6-alpine

# --- Vector Stores ---
WEAVIATE_VERSION=1.27.0
QDRANT_VERSION=v1.8.3

# --- Infrastructure ---
SANDBOX_VERSION=0.2.14
SQUID_VERSION=latest
NGINX_VERSION=latest
CERTBOT_VERSION=v3.1.0
PLUGIN_DAEMON_VERSION=0.5.3-local

# --- ETL ---
DOCLING_IMAGE_CPU=ghcr.io/docling-project/docling-serve:v1.14.3
DOCLING_IMAGE_CUDA=quay.io/docling-project/docling-serve-cu128:v1.14.3

# --- AI Gateway ---
LITELLM_VERSION=v1.82.3-stable.patch.2

# --- Optional Services ---
SEARXNG_VERSION=2026.3.29-7ac4ff39f
SURREALDB_VERSION=v2.2.1
OPEN_NOTEBOOK_VERSION=v1-latest
DBGPT_VERSION=v0.8.0
CRAWL4AI_VERSION=0.8.6

# --- Provider Architecture ---
VLLM_VERSION=v0.18.1
VLLM_CUDA_SUFFIX=
TEI_VERSION=cuda-1.9.3
TEI_EMBED_VERSION=cuda-1.9.3
TEI_RERANK_VERSION=cpu-1.9.3

# --- DGX Spark (arm64, SM121, Gemma 4) ---
# LLM: gemma4-cu130 image (requires transformers 5.5+, not in NGC yet)
# Embed/rerank: NGC vLLM with --runner pooling (arm64 native, SM121 support)
VLLM_SPARK_IMAGE=vllm/vllm-openai:gemma4-cu130
VLLM_SPARK_MODEL=google/gemma-4-26B-A4B-it
VLLM_NGC_VERSION=26.03-py3
VLLM_EMBED_MODEL=deepvk/USER-bge-m3
VLLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- Authelia ---
AUTHELIA_VERSION=4.38

# --- Monitoring ---
GRAFANA_VERSION=12.4.1
PORTAINER_VERSION=2.21.4
NODE_EXPORTER_VERSION=v1.8.2
CADVISOR_VERSION=v0.55.1
PROMETHEUS_VERSION=v2.54.1
ALERTMANAGER_VERSION=v0.27.0
LOKI_VERSION=3.3.2
PROMTAIL_VERSION=3.3.2
