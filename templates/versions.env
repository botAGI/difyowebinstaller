# --- Core ---
DIFY_VERSION=1.13.3
OPENWEBUI_VERSION=v0.8.12
# Open WebUI Pipelines — нет semver releases. Pin: tag@digest (Docker syntax accepts both).
# Чтобы обновить: docker pull ghcr.io/open-webui/pipelines:main && \
#   docker inspect --format '{{.RepoDigests}}' ghcr.io/open-webui/pipelines:main
# и подставить новый sha256 ниже. Verified arm64 на 2026-04-25.
PIPELINES_VERSION=main@sha256:b48e9bc338ce2be0acfbeff01810db72408a12f07739f9e3879c1f2b00952d6e
OLLAMA_VERSION=0.21.2
# NOTE: Ollama 0.20.x is available but major jump from 0.6 — test before upgrading
POSTGRES_VERSION=16-alpine3.23
REDIS_VERSION=7.4.8-alpine

# --- Vector Stores ---
WEAVIATE_VERSION=1.27.0
# NOTE: Weaviate 1.36.9 available — requires data migration testing
QDRANT_VERSION=v1.8.3
# NOTE: Qdrant 1.17.1 available — requires data migration testing

# --- Infrastructure ---
SANDBOX_VERSION=0.2.14
SQUID_VERSION=6.6-24.04_edge
NGINX_VERSION=1.29.8-alpine
CERTBOT_VERSION=v3.1.0
MINIO_VERSION=RELEASE.2024-11-07T00-52-20Z
# MinIO Client (mc) — used by install.sh для bucket bootstrap + S3 service account.
# Forward-compatible с MinIO server 2024-11. arm64 manifest verified 2026-04-25.
MC_VERSION=RELEASE.2025-08-13T08-35-41Z
PLUGIN_DAEMON_VERSION=0.5.3-local
# Golden stable — pinned by upstream Dify 1.13.3 itself in their docker-compose.yaml
# 0.5.4: null-content regression (#640) breaks agent tool calling + uv --offline (#649) breaks install
# 0.5.5: reverts uv --offline but STILL carries #640
# 0.5.6: broken auto-migrate (#672 removed migrate, CLI missing from image, #521)
# Unblock when upstream ships 0.5.7 fixing #640 and re-adding migrate

# --- ETL ---
DOCLING_IMAGE_CPU=ghcr.io/docling-project/docling-serve:v1.16.1
DOCLING_IMAGE_CUDA=quay.io/docling-project/docling-serve-cu130:v1.16.1

# --- AI Gateway ---
LITELLM_VERSION=v1.82.3-stable.patch.2
# NOTE: LiteLLM 1.83.x is nightly — wait for stable release

# --- Optional Services ---
SEARXNG_VERSION=2026.4.24-a7ac696b4
SURREALDB_VERSION=v2.6.5
# NOTE: SurrealDB v3.0.5 available — major version, breaking API changes
# Open Notebook — semver pinned (последние upstream фиксы безопасности v1.8.3+v1.8.4 + v1.8.5 features). arm64 verified 2026-04-25.
OPEN_NOTEBOOK_VERSION=1.8.5
DBGPT_VERSION=v0.8.0
CRAWL4AI_VERSION=0.8.6

# --- Provider Architecture ---
VLLM_VERSION=v0.19.0
VLLM_CUDA_SUFFIX=
TEI_VERSION=cuda-1.9.3
TEI_EMBED_VERSION=cuda-1.9.3
TEI_RERANK_VERSION=cpu-1.9.3

# --- DGX Spark (arm64, SM121, Gemma 4) ---
# LLM: gemma4-cu130 image (requires transformers 5.5+, not in NGC yet)
# Embed/rerank: NGC vLLM with --runner pooling (arm64 native, SM121 support)
# NGC 26.03 requires driver 595.45+ but DGX Spark ships 580.142 — use 26.02
# WARNING: DO NOT update VLLM_SPARK_IMAGE or VLLM_NGC_VERSION without testing on Spark hardware
VLLM_SPARK_IMAGE=vllm/vllm-openai:gemma4-cu130
VLLM_SPARK_MODEL=google/gemma-4-26B-A4B-it
VLLM_NGC_VERSION=26.02-py3
VLLM_EMBED_MODEL=deepvk/USER-bge-m3
VLLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- Authelia ---
AUTHELIA_VERSION=4.38
# NOTE: Authelia 4.39.x available — config format may change, test before upgrading

# --- Monitoring ---
GRAFANA_VERSION=12.4.3
PORTAINER_VERSION=2.36.0
NODE_EXPORTER_VERSION=v1.11.1
CADVISOR_VERSION=v0.55.1
# Phase 38: per-service exporters (redis/pg/nginx)
REDIS_EXPORTER_VERSION=v1.82.0
POSTGRES_EXPORTER_VERSION=v0.19.1
NGINX_EXPORTER_VERSION=1.5.1

# Phase 40: load testing (manual-run only, profile: loadtest)
K6_VERSION=0.55.2
PROMETHEUS_VERSION=v2.54.1
# NOTE: Prometheus v3.x available — major version, new storage format
ALERTMANAGER_VERSION=v0.32.0
LOKI_VERSION=3.6.10
PROMTAIL_VERSION=3.6.10

# SOPS — secrets encryption tool downloaded from GitHub releases (lib/security.sh).
# SHA256 mandatory: refuse install if mismatch. Verify via checksums.txt at:
# https://github.com/getsops/sops/releases/download/v3.12.2/sops-v3.12.2.checksums.txt
SOPS_VERSION=v3.12.2
SOPS_SHA256_ARM64=f66de6f528dca946e910d74fa36a62a7714c11d0db16bd3c9bd8acf73b66704b
SOPS_SHA256_AMD64=14e2e1ba3bef31e74b70cf0b674f6443c80f6c5f3df15d05ffc57c34851b4998
