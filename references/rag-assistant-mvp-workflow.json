      {
        "id": "code_list",
        "type": "custom",
        "data": {
          "type": "code",
          "title": "Формат списка",
          "code_language": "python3",
          "code": "import json\n\ndef main(body: str) -> dict:\n    try:\n        data = json.loads(body)\n        docs = data.get(\"data\", [])\n        if not docs:\n            return {\"result\": \"База знаний пуста. Загрузите документ через скрепку.\"}\n        lines = [\"Документы в базе знаний:\\n\"]\n        for i, doc in enumerate(docs, 1):\n            name = doc.get(\"name\", \"?\")\n            doc_id = doc.get(\"id\", \"?\")\n            words = doc.get(\"word_count\", 0)\n            status = \"OK\" if doc.get(\"indexing_status\") == \"completed\" else \"...\"\n            lines.append(str(i) + \". [\" + status + \"] \" + name + \" (\" + str(words) + \" слов)\")\n            lines.append(\"   /delete \" + doc_id)\n        lines.append(\"\\nДля удаления скопируйте команду /delete с ID\")\n        return {\"result\": \"\\n\".join(lines)}\n    except Exception as e:\n        return {\"result\": \"Ошибка: \" + str(e)}\n",
          "variables": [
            {
              "variable": "body",
              "value_selector": [
                "http_list",
                "body"
              ]
            }
          ],
          "outputs": {
            "result": {
              "type": "string",
              "children": null
            }
          },
          "selected": false
        },
