# tests/golden/inputs/minimal_lan.env
# AUTO-MANAGED — see tests/golden/UPDATE.md before editing.
# Self-contained scenario fixture (D-03): every variable that lib/config.sh::generate_config
# expects must be defined here. No merging with a baseline.
# Format: bash-source-compatible (set -a; source <file>; set +a).

# ───────────────────── Common defaults (LAN profile) ─────────────────────
DEPLOY_PROFILE=lan
DOMAIN=agmind-dify.local
TZ=Europe/Moscow
ALLOW_NONFREE_VLM=true

# Provider architecture
LLM_PROVIDER=vllm
EMBED_PROVIDER=vllm
ENABLE_DIFY_PREMIUM=false

# Scenario-distinguishing (minimal: weaviate, no monitoring, no minio)
VECTOR_STORE=weaviate
ENABLE_MINIO=false
ENABLE_RERANKER=false
ENABLE_RAGFLOW=false
ENABLE_AUTHELIA=false
MONITORING_MODE=none
CLUSTER_MODE=single
LLM_ON_PEER=false
ENABLE_DOCLING=false

# Secrets — generated by generate_random_named under AGMIND_TEST_SEED
# (deterministic). Other env vars left unset — generate_config falls back to
# documented defaults.
