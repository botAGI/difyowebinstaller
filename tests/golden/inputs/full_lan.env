# tests/golden/inputs/full_lan.env
# AUTO-MANAGED — see tests/golden/UPDATE.md before editing.
# Self-contained scenario fixture (D-03).

DEPLOY_PROFILE=lan
DOMAIN=agmind-dify.local
TZ=Europe/Moscow
ALLOW_NONFREE_VLM=true

LLM_PROVIDER=vllm
EMBED_PROVIDER=vllm
ENABLE_DIFY_PREMIUM=false

# Typical demo: weaviate + minio + reranker + docling + monitoring + authelia
VECTOR_STORE=weaviate
ENABLE_MINIO=true
ENABLE_RERANKER=true
ENABLE_RAGFLOW=false
ENABLE_AUTHELIA=true
MONITORING_MODE=local
CLUSTER_MODE=single
LLM_ON_PEER=false
ENABLE_DOCLING=true
