# tests/golden/inputs/ragflow.env
# AUTO-MANAGED — see tests/golden/UPDATE.md before editing.
# Self-contained scenario fixture (D-03).

DEPLOY_PROFILE=lan
DOMAIN=agmind-dify.local
TZ=Europe/Moscow
ALLOW_NONFREE_VLM=true

LLM_PROVIDER=vllm
EMBED_PROVIDER=vllm
ENABLE_DIFY_PREMIUM=false

# RAGFlow profile activated — generates ragflow/service_conf.yaml
VECTOR_STORE=weaviate
ENABLE_MINIO=true
ENABLE_RERANKER=true
ENABLE_RAGFLOW=true
ENABLE_AUTHELIA=false
MONITORING_MODE=local
CLUSTER_MODE=single
LLM_ON_PEER=false
ENABLE_DOCLING=true
