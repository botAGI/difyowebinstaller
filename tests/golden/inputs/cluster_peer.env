# tests/golden/inputs/cluster_peer.env
# AUTO-MANAGED — see tests/golden/UPDATE.md before editing.
# Self-contained scenario fixture (D-03).

DEPLOY_PROFILE=lan
DOMAIN=agmind-dify.local
TZ=Europe/Moscow
ALLOW_NONFREE_VLM=true

LLM_PROVIDER=vllm
EMBED_PROVIDER=vllm
ENABLE_DIFY_PREMIUM=false

# Cluster mode: LLM_ON_PEER=true — vLLM runs on peer Spark, not master
VECTOR_STORE=weaviate
ENABLE_MINIO=true
ENABLE_RERANKER=true
ENABLE_RAGFLOW=false
ENABLE_AUTHELIA=false
MONITORING_MODE=local
CLUSTER_MODE=cluster
LLM_ON_PEER=true
ENABLE_DOCLING=true
PEER_HOST=spark-69a2.local
PEER_SSH_USER=agmind
# Required для _configure_peer_monitoring to activate peer scrape jobs:
# AGMIND_MODE=master + PEER_IP. Other 4 scenarios leave AGMIND_MODE unset
# (defaults to "single") → peer monitoring stays commented.
AGMIND_MODE=master
PEER_IP=192.168.100.2
