BROKER_USE_SSL=false

# --- Init Admin ---
INIT_PASSWORD=SVo3Q1pjTVNSTjRoQm5NOQ==

# --- URLs (empty = auto from browser) ---
CONSOLE_WEB_URL=
CONSOLE_API_URL=
SERVICE_API_URL=
APP_API_URL=
APP_WEB_URL=
FILES_URL=http://172.17.0.1

# --- Storage ---
STORAGE_TYPE=s3

# --- MinIO Object Storage ---
ENABLE_MINIO=true
MINIO_ROOT_USER=agmind-admin
MINIO_ROOT_PASSWORD=izrKG7yKcgFahJ6ADMiKRNG0Rf4Qqilj
S3_ENDPOINT=http://minio:9000
S3_BUCKET_NAME=dify-storage
S3_ACCESS_KEY=mRWs6XOf5s438hPtXC4M
S3_SECRET_KEY=8OMqkRbsnvMVJZk2LqLoGPo1yVdNNFCHvtqHNs2A
S3_REGION=us-east-1
S3_USE_AWS_MANAGED_IAM=false

# --- Vector Store ---
# VECTOR_STORE: weaviate (default) | qdrant | milvus (experimental — needs MinIO,
# Dify-only, RAGFlow uses its own ES regardless of this setting)
VECTOR_STORE=milvus
WEAVIATE_ENDPOINT=http://weaviate:8080
WEAVIATE_API_KEY=HmUCsffSlMmhdPkUEZ5pEbiVqPJyF1G8
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=MIDqw0AxFM0jIfD0xL0V0Sq931eVLUVF
# Milvus knobs (active only when VECTOR_STORE=milvus). Defaults from compose.
# MILVUS_URI=http://milvus:19530   MILVUS_DATABASE=agmind
# MILVUS_MEM_LIMIT=16g  MILVUS_ETCD_MEM_LIMIT=1g  MILVUS_BIND_ADDR=127.0.0.1

# --- ETL ---
ETL_TYPE=Unstructured
UNSTRUCTURED_API_URL=http://docling:8765

# --- Document Processing ---
ENABLE_DOCLING=false
DOCLING_IMAGE=
OCR_LANG=rus,eng
NVIDIA_VISIBLE_DEVICES=

# --- Marketplace ---
# Default ONLINE — большинство юзеров ставят плагины из marketplace.dify.ai.
# Выключить если supply-chain risk критичен: agmind plugins offline
MARKETPLACE_ENABLED=true
CHECK_UPDATE_URL=https://updates.dify.ai

# --- Sandbox ---
SANDBOX_ENABLE_NETWORK=true
SANDBOX_PORT=8194
SANDBOX_WORKER_TIMEOUT=15

# --- SSRF Proxy ---
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128

# --- Ollama ---
OLLAMA_API_BASE=http://ollama:11434
LLM_MODEL=qwen2.5:14b
EMBEDDING_MODEL=bge-m3

# --- Provider Architecture ---
LLM_PROVIDER=vllm
EMBED_PROVIDER=vllm
TEI_EMBED_VERSION=
VLLM_MODEL=QuantTrio/Qwen3.5-27B-AWQ
HF_TOKEN=

# --- Reranker ---
ENABLE_RERANKER=true
TEI_RERANK_VERSION=cpu-1.9.3
RERANK_MODEL=

# --- LiteLLM (AI Gateway) ---
LITELLM_MASTER_KEY=sk-Zl5nAyZDDuxiiQQ2Jg1YVj3wQisq2vom
ENABLE_LITELLM=true

# --- Optional Services ---
ENABLE_SEARXNG=false
ENABLE_NOTEBOOK=false
ENABLE_DBGPT=false
ENABLE_CRAWL4AI=false
ENABLE_N8N=false
ENABLE_OPENWEBUI=false
ENABLE_DIFY_PREMIUM=false
ENABLE_RAGFLOW=false
SEARXNG_SECRET_KEY=iUN9UUxTx8FtdzvLXIQzcuglc4WhNCro
SURREALDB_PASSWORD=v25RTL2ZQ3jWsXTPL7uuaF89
NOTEBOOK_ENCRYPTION_KEY=r5fVU756d7ja5LdLYHxWg6YN23mpV4kO
N8N_ENCRYPTION_KEY=
N8N_DB_DATABASE=n8n
N8N_BIND_ADDR=127.0.0.1
EXPOSE_N8N_PORT=5678
# Optional n8n overrides — uncomment to customise:
# N8N_HOST=localhost   N8N_WEBHOOK_URL=http://<host>:5678/   N8N_TIMEZONE=UTC   N8N_MEM_LIMIT=1g
EXPOSE_DBGPT_PORT=5670
EXPOSE_NOTEBOOK_PORT=8502
EXPOSE_NOTEBOOK_API_PORT=5055
OPEN_NOTEBOOK_API_URL=http://agmind-notebook.local:5055
EXPOSE_SEARXNG_PORT=8888
EXPOSE_CRAWL4AI_PORT=11235
EXPOSE_DOCLING_PORT=8765

# --- Nginx ---
EXPOSE_NGINX_PORT=80
EXPOSE_NGINX_SSL_PORT=443
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_HTTPS_ENABLED=false
NGINX_SERVER_NAME=_

# --- Open WebUI ---
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=user

# --- Plugin Daemon ---
PLUGIN_DAEMON_PORT=5002
PLUGIN_DB_DATABASE=dify_plugin
PLUGIN_STORAGE_TYPE=local
PLUGIN_STORAGE_LOCAL_PATH=/app/storage
PLUGIN_DIFY_INNER_API_URL=http://api:5001
MAX_PLUGIN_PACKAGE_SIZE=52428800
PLUGIN_PPROF_ENABLED=false

# --- Other versions ---

# --- TLS ---
TLS_MODE=none

# --- Monitoring ---
MONITORING_MODE=local
MONITORING_ENDPOINT=
MONITORING_TOKEN=
GRAFANA_PORT=3001
GRAFANA_BIND_ADDR=127.0.0.1
GRAFANA_ADMIN_PASSWORD=vIDeEwTZd914U5BO
PORTAINER_PORT=9443
PORTAINER_BIND_ADDR=127.0.0.1
# Shared secret для master Portainer ↔ peer Portainer Agent (port 9001).
# Persistent в /opt/agmind/.secrets/portainer_agent_secret.
PORTAINER_AGENT_SECRET=mz9ArhDDHSqmen6hWPoCwL6aWCKQ26Fh
PORTAINER_AGENT_VERSION=2.41.1

# --- Alerts (default: none; customer chooses channel via wizard) ---
# Opt-in channels — ALERT_MODE picks which block in alertmanager.yml is active.
# One of: none | telegram | email | webhook
ALERT_MODE=none
ALERT_WEBHOOK_URL=
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_EMAIL_SMARTHOST=
ALERT_EMAIL_AUTH_USER=
ALERT_EMAIL_AUTH_PASS=

# --- New service versions ---

# --- Security ---
ENABLE_UFW=false
ENABLE_FAIL2BAN=true
ENABLE_SOPS=false
SKIP_DOCKER_HARDENING=false
ENABLE_SECRET_ROTATION=false
LAN_SUBNET=192.168.0.0/16
SKIP_PREFLIGHT=false
SKIP_GPU_DETECT=false
FORCE_GPU_TYPE=

# --- Deploy ---
# Deployment profile (one of: core rag ragflow observability security agents full dev custom).
# Overwritten at install time by the wizard / --profile flag.
DEPLOY_ENV=PRODUCTION
LOG_LEVEL=INFO
MIGRATION_ENABLED=true
NEXT_TELEMETRY_DISABLED=1
FORCE_VERIFYING_SIGNATURE=true
# Dify 1.14.1 defaults ENABLE_COLLABORATION_MODE=True → expects a separate websocket
# service. Single-tenant LAN profile doesn't run that service — disable explicitly.
ENABLE_COLLABORATION_MODE=false

# --- Authelia ---
ENABLE_AUTHELIA=false
AUTHELIA_JWT_SECRET=j4zRE01MIQQpKA68BBzqx7D35GXIUwQwtKIVavNYuvTtu963YRhFH0SFtum8Thyj

# --- Healthchecks ---
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_RETRIES=5

# --- Backup Options ---
BACKUP_RETENTION_COUNT=10
ENABLE_S3_BACKUP=false
ENABLE_BACKUP_ENCRYPTION=false
S3_REMOTE_NAME=s3
S3_BUCKET=agmind-backups
S3_PATH=

# --- Loki ---
ENABLE_LOKI=true

# --- Performance tuning (added 2026-04-20) ---

# Docling — larger batches for GPU utilization (safe on DGX Spark 121 GiB unified)
# (also set in docker-compose.yml docling.environment)
DOCLING_SERVE_LAYOUT_BATCH_SIZE=64
DOCLING_SERVE_OCR_BATCH_SIZE=64

# --- Upload limits (upstream Dify defaults are too conservative for KB ingest) ---
UPLOAD_FILE_SIZE_LIMIT=500
UPLOAD_FILE_BATCH_LIMIT=50
BATCH_UPLOAD_LIMIT=100
WORKFLOW_FILE_UPLOAD_LIMIT=50

# --- RAGFlow (BACKLOG #999.7) ---
# Enable through wizard: добавит ragflow + ragflow_mysql + ragflow_es01 services.
# Integration with Dify через plugin witmeng/ragflow-api (install после первого старта).
# Memory: ~10-15 GiB total (ragflow 8g + es 4g + mysql 1g). Spark 121 GiB unified — fits.
# DEVICE=gpu по умолчанию: vLLM на peer (LLM_ON_PEER=true), master GPU свободен ~95 GiB.
# Откат на cpu: RAGFLOW_DEVICE=cpu в .env, restart.
RAGFLOW_MEM_LIMIT=8g
RAGFLOW_ES_MEM_LIMIT=4g
RAGFLOW_MYSQL_MEM_LIMIT=1g
RAGFLOW_DEVICE=cuda
RAGFLOW_MYSQL_PASSWORD=7zmygodbKeBGn1PKHnDapgXUgl3NwRyW
RAGFLOW_ES_PASSWORD=qcZDMRxG4s3iNmlSlLXCIayb5sKk80UT
RAGFLOW_MINIO_USER=ragflow
RAGFLOW_MINIO_PASSWORD=d9TalvdznDRHUqypdRJRJhFyzPEq7U3w
# API key + dataset_id — заполнить ВРУЧНУЮ после первого старта RAGFlow UI:
#   1. Открыть http://<host>:9380/  (или через nginx если выставлено)
#   2. Profile → API → API Keys → Create
#   3. Создать dataset, скопировать ID из URL
#   4. Прописать сюда → docker compose restart api worker (для plugin)
RAGFLOW_API_KEY=
RAGFLOW_DATASET_ID=

# --- Provider-specific WebUI vars (via LiteLLM) ---
OLLAMA_BASE_URL=
ENABLE_OLLAMA_API=false
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://agmind-litellm:4000/v1
LLM_ON_PEER=false
DEPLOY_PROFILE=lan
DBGPT_API_BASE=http://litellm:4000/v1
DBGPT_API_KEY=
DOCKER_GID=988

