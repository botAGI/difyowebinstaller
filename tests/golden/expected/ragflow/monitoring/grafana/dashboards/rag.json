{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "title": "AGMind RAG Pipeline",
  "uid": "agmind-rag",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "tags": ["agmind", "rag"],
  "panels": [
    {
      "title": "Active vLLM Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(vllm:num_requests_running)", "legendFormat": "running", "refId": "A" },
        { "expr": "sum(vllm:num_requests_waiting)", "legendFormat": "waiting", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" }
    },
    {
      "title": "KV Cache Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "vllm:kv_cache_usage_perc{service=\"llm\"} * 100", "legendFormat": "llm", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Host RAM Available",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "free %", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "title": "Host Swap Used",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "((node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes) / node_memory_SwapTotal_bytes) * 100", "legendFormat": "swap used", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" }
    },
    {
      "title": "vLLM TTFT (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(vllm:time_to_first_token_seconds_bucket{service=\"llm\"}[5m]))", "legendFormat": "p50 llm", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket{service=\"llm\"}[5m]))", "legendFormat": "p95 llm", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(vllm:time_to_first_token_seconds_bucket{service=\"llm\"}[5m]))", "legendFormat": "p99 llm", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "vLLM E2E Latency (p95 by service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(vllm:e2e_request_latency_seconds_bucket[5m])))", "legendFormat": "p95 {{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "vLLM Throughput (tokens/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(vllm:generation_tokens_total{service=\"llm\"}[5m])", "legendFormat": "gen tok/s", "refId": "A" },
        { "expr": "rate(vllm:prompt_tokens_total{service=\"llm\"}[5m])", "legendFormat": "prompt tok/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "vLLM Prefix Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "100 * (sum by (service) (rate(vllm:prefix_cache_hits_total[5m])) / clamp_min(sum by (service) (rate(vllm:prefix_cache_queries_total[5m])), 0.001))", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "title": "Weaviate Query Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(vector_index_durations_ms_bucket[5m]))", "legendFormat": "p95 ms", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Weaviate Object Count by Class",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "sum by (class_name) (object_count)", "legendFormat": "{{class_name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Postgres Connections (% of max)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 28 },
      "targets": [
        { "expr": "sum(pg_stat_activity_count) / on() pg_settings_max_connections * 100", "legendFormat": "used %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "title": "Redis Commands/sec",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 28 },
      "targets": [
        { "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "cmds/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Nginx Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 28 },
      "targets": [
        { "expr": "nginx_connections_active", "legendFormat": "active", "refId": "A" },
        { "expr": "nginx_connections_waiting", "legendFormat": "waiting", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}
