#!/usr/bin/env bash
# stat passthrough mock — extensible fixture overrides for `-c <FMT>` queries.
# Supported fixtures:
#   MOCK_STAT_FIXTURE=644      → returned for -c %a / %A (mode bits)
#   MOCK_STAT_GID_FIXTURE=988  → returned for -c %g (group ID — needed by
#                                 golden harness to neutralize host docker GID drift)
# Any unrecognized format string falls through to real /usr/bin/stat.
set -euo pipefail

_args="$*"

# Mode-bits fixture (-c %a / %A)
if [[ -n "${MOCK_STAT_FIXTURE:-}" ]]; then
    for _a in "$@"; do
        case "$_a" in
            '%a'|'%a '|'%A') echo "${MOCK_STAT_FIXTURE}"; exit 0 ;;
        esac
    done
    if [[ "$_args" == *"%a"* ]]; then
        echo "${MOCK_STAT_FIXTURE}"
        exit 0
    fi
fi

# Group-ID fixture (-c %g) — used by lib/config.sh DOCKER_GID detection.
# Without this, golden harness leaks host docker GID into snapshots (CI ≠ dev).
if [[ -n "${MOCK_STAT_GID_FIXTURE:-}" ]]; then
    for _a in "$@"; do
        case "$_a" in
            '%g') echo "${MOCK_STAT_GID_FIXTURE}"; exit 0 ;;
        esac
    done
    if [[ "$_args" == *"%g"* ]]; then
        echo "${MOCK_STAT_GID_FIXTURE}"
        exit 0
    fi
fi

# No fixture set or no match — passthrough to real stat
exec /usr/bin/stat "$@"
