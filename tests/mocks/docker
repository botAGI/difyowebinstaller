#!/usr/bin/env bash
# Mock for docker — keyed by MOCK_DOCKER_FIXTURE env var.
# Fixtures: healthy | no_daemon | gpu_caps_missing
# Appends invoked argv to MOCK_DOCKER_CALLLOG for --fix/--dry-run assertions.
#
# Phase 2 additions (additive — existing fixtures intact):
#   MOCK_DOCKER_PS_FIXTURE: multi_state | init_exited | restart_loop (+ existing running|unhealthy|none|empty)
#   MOCK_DOCKER_INSPECT_FIXTURE: ok (default) | restart_loop | missing
#   MOCK_DOCKER_HEALTH_FIXTURE: default | unhealthy_worker | starting_vllm | distroless_loki
#   MOCK_DOCKER_STATS_FIXTURE: ok (default) | unavailable
#   docker stats / docker logs branches added
#
# Phase 5 additions (additive — existing fixtures intact):
#   MOCK_DOCKER_VOLUME_FIXTURE: empty (default) | with_openwebui | with_ollama | full
#   MOCK_DOCKER_COMPOSE_STOP_FIXTURE: ok (default) | fail
#   MOCK_DOCKER_COMPOSE_UP_FIXTURE: ok (default) | fail
#   MOCK_DOCKER_EXEC_PSQL_FIXTURE: ok (default) | fail
#   docker volume ls / compose stop|up|down|start / exec psql|pg_isready branches added
#
# Phase 4 additions (additive — existing fixtures intact):
#   MOCK_DOCKER_INFO_EXIT: when set to non-zero, `docker info` exits with that code (simulate daemon down)
#   MOCK_DOCKER_PS_FIXTURE: two_running — `docker ps -a --format {{.Names}} {{.State}}` new form
#   MOCK_DOCKER_HEALTH_FIXTURE: unhealthy_vllm — for `docker inspect --format {{.State.Health.Status}}`
#   MOCK_DOCKER_COMPOSE_CONFIG_EXIT: exit code for `docker compose ... config -q` (default 0)
#   MOCK_DOCKER_COMPOSE_CONFIG_OUTPUT: stderr output when config -q exits non-zero
#   MOCK_DOCKER_COMPOSE_CONFIG_RENDERED_FILE: file path to cat for `docker compose ... config` (no -q)
set -euo pipefail

# Call-log: always record invocation so tests can assert docker was/wasn't called.
printf '%s\n' "docker $*" >> "${MOCK_DOCKER_CALLLOG:-/dev/null}"

case "${MOCK_DOCKER_FIXTURE:-healthy}" in
    healthy)
        case "${1:-}" in
            version)
                if [[ "${2:-}" == "--format" ]]; then
                    echo "29.0.3"
                else
                    echo "Docker version 29.0.3, build abc123"
                fi
                ;;
            compose)
                case "${2:-}" in
                    version)
                        if [[ "${3:-}" == "--short" ]]; then
                            echo "v2.27.0"
                        else
                            echo "Docker Compose version v2.27.0"
                        fi
                        ;;
                    config)
                        # Phase 4: detect -q flag in remaining args
                        _cfg_q=0
                        for _cfg_a in "$@"; do
                            [[ "$_cfg_a" == "-q" ]] && _cfg_q=1
                        done
                        if [[ "$_cfg_q" -eq 1 ]]; then
                            # docker compose ... config -q
                            # MOCK_DOCKER_COMPOSE_CONFIG_EXIT: exit code (default 0)
                            # MOCK_DOCKER_COMPOSE_CONFIG_OUTPUT: stderr on non-zero exit
                            _cfg_exit="${MOCK_DOCKER_COMPOSE_CONFIG_EXIT:-0}"
                            if [[ "$_cfg_exit" != "0" ]]; then
                                echo "${MOCK_DOCKER_COMPOSE_CONFIG_OUTPUT:-compose config error}" >&2
                                exit "${_cfg_exit}"
                            fi
                            exit 0
                        else
                            # docker compose ... config (no -q) — render effective config
                            # MOCK_DOCKER_COMPOSE_CONFIG_RENDERED_FILE: path to cat (default: fake content)
                            if [[ -n "${MOCK_DOCKER_COMPOSE_CONFIG_RENDERED_FILE:-}" && -f "${MOCK_DOCKER_COMPOSE_CONFIG_RENDERED_FILE}" ]]; then
                                cat "${MOCK_DOCKER_COMPOSE_CONFIG_RENDERED_FILE}"
                            else
                                # Intentional fake secret line for bundle sanitizer test (T-01-02)
                                printf 'services:\n  example:\n    image: agmind/example:1.0\n    environment:\n      DB_PASSWORD: notreal_pw_in_mock_only\n'
                            fi
                        fi
                        ;;
                    stop)
                        # docker compose stop <names> — selective restore (Phase 5)
                        case "${MOCK_DOCKER_COMPOSE_STOP_FIXTURE:-ok}" in
                            ok)   exit 0 ;;
                            fail) exit 1 ;;
                            *)    exit 0 ;;
                        esac
                        ;;
                    up)
                        # docker compose up -d <names> — selective restore start (Phase 5)
                        case "${MOCK_DOCKER_COMPOSE_UP_FIXTURE:-ok}" in
                            ok)   exit 0 ;;
                            fail) exit 1 ;;
                            *)    exit 0 ;;
                        esac
                        ;;
                    down)
                        # full compose down — used by restore_apply non-selective path (Phase 5)
                        exit 0
                        ;;
                    start)
                        # docker compose start <names> (Phase 5)
                        exit 0
                        ;;
                    *)
                        exit 0
                        ;;
                esac
                ;;
            volume)
                # docker volume ls [-q] — keyed by MOCK_DOCKER_VOLUME_FIXTURE (Phase 5)
                if [[ "${2:-}" == "ls" ]]; then
                    case "${MOCK_DOCKER_VOLUME_FIXTURE:-empty}" in
                        empty)          : ;;  # no volumes
                        with_openwebui) printf 'agmind_openwebui_data\n' ;;
                        with_ollama)    printf 'agmind_ollama_data\n' ;;
                        full)           printf 'agmind_openwebui_data\nagmind_ollama_data\nagmind_weaviate\n' ;;
                        *)              : ;;
                    esac
                fi
                exit 0
                ;;
            info)
                # Phase 4: MOCK_DOCKER_INFO_EXIT — simulate docker daemon down
                if [[ -n "${MOCK_DOCKER_INFO_EXIT:-}" && "${MOCK_DOCKER_INFO_EXIT}" != "0" ]]; then
                    echo "Cannot connect to the Docker daemon at unix:///var/run/docker.sock" >&2
                    exit "${MOCK_DOCKER_INFO_EXIT}"
                fi
                printf 'Server Version: 29.0.3\nRuntimes: io.containerd.runc.v2 nvidia runc\nDefault Runtime: runc\n'
                ;;
            ps)
                # Detect filtered status query:
                # lib/status.sh calls: docker ps -a --filter "name=^agmind-X$" --format '{{.Status}}'
                # We detect by scanning argv for both a name=^agmind-...$ filter AND '{{.Status}}' format.
                _ps_has_filter=0
                _ps_has_status_fmt=0
                _ps_filter_name=""
                for _ps_arg in "$@"; do
                    case "$_ps_arg" in
                        --filter) : ;;
                        name=\^agmind-*\$)
                            _ps_has_filter=1
                            # Extract short name: strip "name=^agmind-" prefix and "$" suffix
                            _ps_filter_name="${_ps_arg#name=^agmind-}"
                            _ps_filter_name="${_ps_filter_name%\$}"
                            ;;
                        '{{.Status}}') _ps_has_status_fmt=1 ;;
                    esac
                done

                if [[ "$_ps_has_filter" -eq 1 && "$_ps_has_status_fmt" -eq 1 ]]; then
                    # Filtered status query — return per-container status string
                    case "${MOCK_DOCKER_PS_FIXTURE:-running}" in
                        running)
                            echo "Up 3 hours (healthy)"
                            ;;
                        multi_state)
                            # Different status per container
                            case "$_ps_filter_name" in
                                api)            echo "Up 2 hours (healthy)" ;;
                                worker)         echo "Up 5 minutes (unhealthy)" ;;
                                nginx)          echo "Up 1 hour (healthy)" ;;
                                loki)           echo "Up 30 minutes" ;;
                                alloy)          echo "Up 1 hour" ;;
                                redis-exporter) echo "Up 1 hour" ;;
                                nginx-exporter) echo "Up 1 hour" ;;
                                vllm)           echo "Up 7 minutes (health: starting)" ;;
                                db)             echo "Up 4 hours (healthy)" ;;
                                redis)          echo "Up 4 hours (healthy)" ;;
                                grafana)        : ;;  # empty = disabled/profile off
                                prometheus)     : ;;
                                alertmanager)   : ;;
                                portainer)      : ;;
                                *)              echo "Up 1 hour (healthy)" ;;
                            esac
                            ;;
                        init_exited)
                            case "$_ps_filter_name" in
                                redis-lock-cleaner) echo "Exited (0) 2 hours ago" ;;
                                k6)                 echo "Exited (0) 1 day ago" ;;
                                *)                  echo "Up 1 hour (healthy)" ;;
                            esac
                            ;;
                        restart_loop)
                            case "$_ps_filter_name" in
                                vllm) echo "Up 2 seconds" ;;
                                *)    echo "Up 1 hour (healthy)" ;;
                            esac
                            ;;
                        unhealthy)
                            case "$_ps_filter_name" in
                                worker) echo "Up 5 minutes (unhealthy)" ;;
                                *)      echo "Up 1 hour (healthy)" ;;
                            esac
                            ;;
                        none|empty)
                            : # nothing
                            ;;
                        *)
                            echo "Up 1 hour (healthy)"
                            ;;
                    esac
                else
                    # Bare docker ps (no name filter) — keep original name-list behavior for test_doctor.sh
                    # Phase 4: also handle `docker ps -a --format '...'` with {{.Names}} and {{.State}}
                    # for install_report services[] query. Detect by format arg containing both fields.
                    _ps_has_names_state_fmt=0
                    for _ps_arg in "$@"; do
                        if [[ "$_ps_arg" == *".Names"* && "$_ps_arg" == *".State"* ]]; then
                            _ps_has_names_state_fmt=1
                        fi
                    done
                    if [[ "$_ps_has_names_state_fmt" -eq 1 ]]; then
                        # Format request containing both .Names and .State — install_report use case
                        case "${MOCK_DOCKER_PS_FIXTURE:-running}" in
                            two_running)
                                printf '{"name":"agmind-api","status":"running"}\n'
                                printf '{"name":"agmind-vllm","status":"running"}\n'
                                ;;
                            running|multi_state)
                                printf '{"name":"agmind-api","status":"running"}\n'
                                printf '{"name":"agmind-vllm","status":"running"}\n'
                                printf '{"name":"agmind-nginx","status":"running"}\n'
                                ;;
                            none|empty)
                                : # nothing — services will be []
                                ;;
                            *)
                                printf '{"name":"agmind-api","status":"running"}\n'
                                printf '{"name":"agmind-vllm","status":"running"}\n'
                                ;;
                        esac
                    else
                        case "${MOCK_DOCKER_PS_FIXTURE:-running}" in
                            running)
                                printf 'agmind-api\nagmind-vllm\nagmind-docling\nagmind-nginx\n'
                                ;;
                            unhealthy)
                                printf 'agmind-api\nagmind-vllm\nagmind-docling\nagmind-nginx\nagmind-worker\t(unhealthy)\n'
                                ;;
                            multi_state)
                                printf 'agmind-api\nagmind-worker\nagmind-nginx\nagmind-loki\nagmind-vllm\nagmind-db\nagmind-redis\n'
                                ;;
                            init_exited)
                                printf 'agmind-api\nagmind-redis-lock-cleaner\nagmind-k6\n'
                                ;;
                            restart_loop)
                                printf 'agmind-vllm\n'
                                ;;
                            two_running)
                                printf 'agmind-api\nagmind-vllm\n'
                                ;;
                            none|empty)
                                : # nothing
                                ;;
                            *)
                                printf 'agmind-api\nagmind-vllm\nagmind-docling\nagmind-nginx\n'
                                ;;
                        esac
                    fi
                fi
                ;;
            exec)
                # Detect a postgres exec (psql / pg_isready / pg_dump) — DB restore/verify path (Phase 5)
                _exec_is_pg=0
                for _e in "$@"; do
                    case "$_e" in psql|pg_isready|pg_dump) _exec_is_pg=1 ;; esac
                done
                if [[ "$_exec_is_pg" -eq 1 ]]; then
                    case "${MOCK_DOCKER_EXEC_PSQL_FIXTURE:-ok}" in
                        ok)   exit 0 ;;
                        fail) exit 1 ;;
                        *)    exit 0 ;;
                    esac
                fi
                # docker exec <container> <cmd> — dispatch on MOCK_DOCKER_EXEC_FIXTURE (GPU path)
                case "${MOCK_DOCKER_EXEC_FIXTURE:-gpu_ok}" in
                    gpu_ok)
                        echo "GPU 0: Grace Blackwell Superchip GB10 (UUID: GPU-0)"
                        ;;
                    gpu_fail)
                        exit 1
                        ;;
                    torch_false)
                        echo "False"
                        ;;
                    torch_true)
                        echo "True"
                        ;;
                    *)
                        echo "GPU 0: Grace Blackwell Superchip GB10 (UUID: GPU-0)"
                        ;;
                esac
                ;;
            inspect)
                # docker inspect <container> [--format '<template>']
                # lib/status.sh uses these --format strings:
                #   '{{.RestartCount}}'
                #   '{{if .State.Health}}{{.State.Health.Status}}{{end}}'
                #   'Image: ... Status: ... StartedAt: ... RestartCount: ...'
                #   '{{if .State.Health}}Last health: {{(index .State.Health.Log 0).Output}}{{end}}'
                #   '{{.State.Pid}}'
                #   '{{range .Config.Cmd}}{{.}} {{end}}'
                # lib/doctor.sh uses bare inspect (no --format) for GPU env → raw JSON
                #
                # Detect which format was requested by scanning argv
                _insp_fmt=""
                _insp_container=""
                _insp_scanning_fmt=0
                for _insp_a in "$@"; do
                    if [[ "$_insp_scanning_fmt" -eq 1 ]]; then
                        _insp_fmt="$_insp_a"
                        _insp_scanning_fmt=0
                    elif [[ "$_insp_a" == "--format" ]]; then
                        _insp_scanning_fmt=1
                    elif [[ "$_insp_a" != "inspect" ]]; then
                        _insp_container="$_insp_a"
                    fi
                done

                # Extract short container name (strip "agmind-" prefix)
                _insp_cname="${_insp_container#agmind-}"

                if [[ -z "$_insp_fmt" ]]; then
                    # Bare docker inspect (no --format) — existence check + GPU env JSON
                    # MOCK_DOCKER_INSPECT_FIXTURE=missing → exit 1 (container not found)
                    if [[ "${MOCK_DOCKER_INSPECT_FIXTURE:-ok}" == "missing" ]]; then
                        echo "Error: No such object: ${_insp_container}" >&2
                        exit 1
                    fi
                    # Default: raw JSON satisfying doctor.sh inspect (RestartCount + GPU env)
                    echo '[{"RestartCount":0,"Mounts":[],"Config":{"Env":["NVIDIA_DRIVER_CAPABILITIES=compute,utility"]}}]'
                elif [[ "$_insp_fmt" == *"RestartCount"* && "$_insp_fmt" != *"Image"* && "$_insp_fmt" != *"Status"* ]]; then
                    # '{{.RestartCount}}' — single-field query
                    case "${MOCK_DOCKER_INSPECT_FIXTURE:-ok}" in
                        restart_loop) echo "47" ;;
                        *)            echo "0" ;;
                    esac
                elif [[ "$_insp_fmt" == *"State.Health"* && "$_insp_fmt" != *"Log"* && "$_insp_fmt" != *"Last health"* ]]; then
                    # '{{if .State.Health}}{{.State.Health.Status}}{{end}}'
                    # OR '{{.State.Health.Status}}' (Phase 4 simple form)
                    # Distroless containers (no healthcheck) → empty string
                    # MOCK_DOCKER_HEALTH_FIXTURE overrides per-container behavior
                    case "${MOCK_DOCKER_HEALTH_FIXTURE:-default}" in
                        unhealthy_worker)
                            case "$_insp_cname" in
                                worker)                                    echo "unhealthy" ;;
                                loki|alloy|redis-exporter|nginx-exporter) : ;;  # distroless
                                *)                                         echo "healthy" ;;
                            esac
                            ;;
                        starting_vllm)
                            case "$_insp_cname" in
                                vllm)                                      echo "starting" ;;
                                loki|alloy|redis-exporter|nginx-exporter) : ;;
                                *)                                         echo "healthy" ;;
                            esac
                            ;;
                        distroless_loki)
                            case "$_insp_cname" in
                                loki)  : ;;  # empty = no healthcheck
                                *)     echo "healthy" ;;
                            esac
                            ;;
                        unhealthy_vllm)
                            # Phase 4: unhealthy_vllm — agmind-vllm is unhealthy, rest healthy
                            case "$_insp_cname" in
                                vllm)                                      echo "unhealthy" ;;
                                loki|alloy|redis-exporter|nginx-exporter) : ;;  # distroless
                                *)                                         echo "healthy" ;;
                            esac
                            ;;
                        *)
                            # Default: distroless services get empty; everything else healthy
                            case "$_insp_cname" in
                                loki|alloy|redis-exporter|nginx-exporter) : ;;  # distroless
                                *)                                         echo "healthy" ;;
                            esac
                            ;;
                    esac
                elif [[ "$_insp_fmt" == *"State.Pid"* ]]; then
                    # '{{.State.Pid}}'
                    echo "12345"
                elif [[ "$_insp_fmt" == *"Config.Cmd"* ]]; then
                    # '{{range .Config.Cmd}}{{.}} {{end}}' — vLLM compose args
                    echo "--enforce-eager gpu_memory_utilization 0.6"
                elif [[ "$_insp_fmt" == *"Last health"* ]] || [[ "$_insp_fmt" == *"State.Health"* && "$_insp_fmt" == *"Log"* ]]; then
                    # '{{if .State.Health}}Last health: {{(index .State.Health.Log 0).Output}}{{end}}'
                    echo "Last health: OK"
                elif [[ "$_insp_fmt" == *"Image"* && "$_insp_fmt" == *"Status"* ]]; then
                    # Multi-field detail template: Image / Status / StartedAt / RestartCount
                    _insp_rc_val="0"
                    if [[ "${MOCK_DOCKER_INSPECT_FIXTURE:-ok}" == "restart_loop" ]]; then
                        _insp_rc_val="47"
                    fi
                    printf 'Image: vllm/vllm-openai:gemma4-cu130\nStatus: running\nStartedAt: 2026-05-11T08:00:00Z\nRestartCount: %s\n' "$_insp_rc_val"
                else
                    # Fallback for any other --format
                    echo "unknown-format-response"
                fi
                ;;
            stats)
                # docker stats --no-stream --format 'CPU: {{.CPUPerc}}   MEM: {{.MemUsage}}' <container>
                # Used by _status_service_detail for resource info.
                case "${MOCK_DOCKER_STATS_FIXTURE:-ok}" in
                    ok)          echo "CPU: 12.3%   MEM: 1.6GiB / 96GiB" ;;
                    unavailable) exit 1 ;;
                    *)           echo "CPU: 12.3%   MEM: 1.6GiB / 96GiB" ;;
                esac
                ;;
            logs)
                # docker logs --tail 30 <container>
                # Used by _status_service_detail for log tail.
                echo "INFO: server started"
                echo "INFO: model loaded successfully"
                echo "INFO: accepting connections on :8000"
                ;;
            image)
                if [[ "${2:-}" == "inspect" ]]; then
                    echo '[{"Id":"sha256:abc123"}]'
                else
                    exit 0
                fi
                ;;
            images)
                printf 'REPOSITORY              TAG    IMAGE ID\nagmind/example          1.0    abc123\n'
                ;;
            system)
                if [[ "${2:-}" == "df" ]]; then
                    printf 'TYPE      TOTAL  ACTIVE  SIZE    RECLAIMABLE\nImages    10     8       12GB    2GB\n'
                else
                    exit 0
                fi
                ;;
            *)
                exit 0
                ;;
        esac
        ;;
    no_daemon)
        echo "Cannot connect to the Docker daemon at unix:///var/run/docker.sock" >&2
        exit 1
        ;;
    gpu_caps_missing)
        case "${1:-}" in
            inspect)
                echo '[{"RestartCount":0,"Mounts":[],"Config":{"Env":["NVIDIA_DRIVER_CAPABILITIES=graphics"]}}]'
                ;;
            exec)
                case "${MOCK_DOCKER_EXEC_FIXTURE:-torch_false}" in
                    torch_false) echo "False" ;;
                    gpu_fail)    exit 1 ;;
                    gpu_ok)      echo "GPU 0: Grace Blackwell Superchip GB10 (UUID: GPU-0)" ;;
                    *)           echo "False" ;;
                esac
                ;;
            ps)
                printf 'agmind-vllm\n'
                ;;
            info)
                printf 'Server Version: 29.0.3\nRuntimes: nvidia runc\n'
                ;;
            version)
                # Handle --format flag same as healthy fixture so docker_version check passes
                if [[ "${2:-}" == "--format" ]]; then
                    echo "29.0.3"
                else
                    echo "Docker version 29.0.3, build abc123"
                fi
                ;;
            compose)
                case "${2:-}" in
                    version)
                        if [[ "${3:-}" == "--short" ]]; then
                            echo "v2.27.0"
                        else
                            echo "Docker Compose version v2.27.0"
                        fi
                        ;;
                    *)
                        exit 0
                        ;;
                esac
                ;;
            *)
                exit 0
                ;;
        esac
        ;;
    *)
        echo "mock docker: unknown MOCK_DOCKER_FIXTURE=${MOCK_DOCKER_FIXTURE:-(unset)}" >&2
        exit 2
        ;;
esac
