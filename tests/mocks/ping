#!/usr/bin/env bash
# Mock ping — keyed by MOCK_PING_FIXTURE env var. Accepts all flags as no-op.
# Fixtures: ok (default) | timeout
# WHY: unit tests must never do real network pings — mdns-status.sh (d) pings the
# primary uplink IP, which times out on CI runners and flaked test_doctor.sh.
case "${MOCK_PING_FIXTURE:-ok}" in
    ok)
        # Last arg is the target host/IP
        echo "PING ${*: -1}: 56 data bytes"
        echo "64 bytes from ${*: -1}: icmp_seq=1 ttl=64 time=0.1 ms"
        exit 0
        ;;
    timeout)
        echo "mock ping: timeout (MOCK_PING_FIXTURE=timeout)" >&2
        exit 1
        ;;
    *)
        echo "mock ping: unknown MOCK_PING_FIXTURE=${MOCK_PING_FIXTURE}" >&2
        exit 2
        ;;
esac
